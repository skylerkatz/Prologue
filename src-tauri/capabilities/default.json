{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-write-text",
    "dialog:allow-open",
    "dialog:allow-message",
    "process:allow-restart",
    "store:default",
    "updater:default"
  ]
}
