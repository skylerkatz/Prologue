{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prologue",
  "version": "0.2.1",
  "identifier": "com.skylerkatz.prologue",
  "build": {
    "beforeDevCommand": "bash scripts/build-sidecar.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && bash scripts/build-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prologue",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data:",
        "font-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'none'"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2RDg1M0U4OUJFRDcxNjUKUldSbGNlMmI2RlBZTnFSdFBhQ2xITTdvTmZCa2h4TlFwUUFBUHBDY2pvdHY2TVp0Q250QU15N0wK",
      "endpoints": [
        "https://github.com/skylerkatz/Prologue/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/prologue-cli"
    ],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
