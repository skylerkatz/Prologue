{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prologue",
  "version": "0.1.0",
  "identifier": "com.skylerkatz.prologue",
  "build": {
    "beforeDevCommand": "bash scripts/build-sidecar.sh && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && bash scripts/build-sidecar.sh",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Prologue",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/prologue"],
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
