{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "withGlobalTauri": true,
    "security": {
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval' 'unsafe-inline'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' data:",
        "font-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost ws://127.0.0.1:* ws://localhost:*",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'none'"
      },
      "capabilities": [
        "default",
        {
          "identifier": "mcp-bridge",
          "description": "Dev-only: lets the injected MCP bridge script report IPC events and script results back to the plugin. Merged in via `tauri dev --config`; never part of release builds.",
          "windows": ["main"],
          "permissions": ["mcp-bridge:default"]
        }
      ]
    }
  }
}
